# Copy to .env and edit. docker-compose auto-loads .env from this directory.
# .env is gitignored.

# --- Audit log database ----------------------------------------------------
# Audit logging is enabled when AUDIT_DB_HOST, AUDIT_DB_USER, and
# AUDIT_DB_PASSWORD are all set. Driver is always mysql+pymysql.
#
#   - For the bundled `mysql` service in docker-compose, use HOST=mysql
#   - For a MySQL on your host machine (Docker Desktop): HOST=host.docker.internal
#   - For a managed/remote MySQL: use its real hostname
#
AUDIT_DB_HOST=mysql
AUDIT_DB_PORT=3306
AUDIT_DB_NAME=httpbin_audit
AUDIT_DB_USER=httpbin
AUDIT_DB_PASSWORD=httpbin

# How long to keep audit rows before the retention thread prunes them.
AUDIT_RETENTION_DAYS=30

# --- Bundled MySQL container (only used when running `mysql` service) ------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=httpbin_audit
MYSQL_USER=httpbin
MYSQL_PASSWORD=httpbin
